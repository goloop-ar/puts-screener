<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Screening {{ run_date }}</title>
  <style>
    :root {
      --bg: #f7f8fa; --card-bg: #ffffff; --border: #e2e5ea; --text: #1c2330;
      --muted: #6b7280; --flag-bg: #fff8e1; --flag-border: #f59e0b; --flag-text: #b45309;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      margin: 0; background: var(--bg); color: var(--text); line-height: 1.45;
    }
    header.page, main, footer { max-width: 1100px; margin: 0 auto; padding: 1rem 1.25rem; }
    header.page h1 { margin: 0 0 0.25rem; font-size: 1.5rem; }
    header.page p { margin: 0; color: var(--muted); }
    main {
      display: grid; gap: 1rem;
      grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
    }
    .card {
      background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px;
      padding: 1rem 1.1rem; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }
    .card-head {
      display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap;
    }
    .ticker { font-size: 1.2rem; }
    .sector, .exchange { color: var(--muted); font-size: 0.82rem; }
    .universe-badges { display: inline-flex; gap: 0.25rem; flex-wrap: wrap; }
    .universe-badge {
      background: #e2e5ea; color: #44505f; padding: 0.1rem 0.4rem;
      border-radius: 4px; font-size: 0.7rem; font-weight: 600;
    }
    .badge {
      margin-left: auto; padding: 0.15rem 0.55rem; border-radius: 999px;
      font-size: 0.78rem; font-weight: 600; color: #ffffff;
    }
    .type-t1 { background: #16a34a; }
    .type-t2 { background: #ea580c; }
    .type-t3 { background: #6b7280; }
    .type-t4 { background: #2563eb; }
    .type-t5 { background: #7c3aed; }
    .zone { display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem; margin: 0.75rem 0; }
    .metric { display: flex; flex-direction: column; }
    .metric .label {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--muted);
    }
    .metric .value { font-weight: 600; }
    .elements h4, .flags h4 { margin: 0.6rem 0 0.3rem; font-size: 0.85rem; }
    .elements ul, .flags ul { margin: 0; padding-left: 1.1rem; font-size: 0.85rem; }
    .elements .more { color: var(--muted); list-style: none; margin-left: -1.1rem; }
    .indicators { font-size: 0.82rem; color: var(--muted); margin-top: 0.6rem; }
    .indicators div { margin: 0.15rem 0; }
    .flags {
      margin-top: 0.7rem; background: var(--flag-bg); border: 1px solid var(--flag-border);
      border-radius: 8px; padding: 0.5rem 0.75rem;
    }
    .flags h4 { color: var(--flag-text); }
    .momentum {
      margin-top: 0.7rem; background: #eef1f5; border: 1px solid var(--border);
      border-radius: 8px; padding: 0.5rem 0.75rem;
    }
    .momentum h4 { margin: 0 0 0.3rem; font-size: 0.85rem; color: var(--muted); }
    .momentum ul { margin: 0; padding-left: 1.1rem; font-size: 0.85rem; }
    .tier { margin: 0.2rem 0 0.05rem; }
    .tier-stars { font-size: 1.3rem; letter-spacing: 1px; }
    .tier-label { color: var(--muted); font-size: 0.85rem; margin-left: 0.4rem; }
    .score-raw { color: var(--muted); font-size: 0.72rem; margin-bottom: 0.3rem; }
    .macro-banner {
      max-width: 1100px; margin: 1rem auto; padding: 12px 16px;
      background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px;
    }
    .macro-banner h2 { font-size: 1.1em; margin: 0 0 8px 0; }
    .macro-banner ul { list-style: none; padding: 0; margin: 0; }
    .macro-banner li { display: flex; gap: 12px; padding: 4px 0; align-items: center; flex-wrap: wrap; }
    .macro-date { font-weight: 600; }
    .macro-days { color: #856404; }
    .macro-kind { padding: 2px 8px; border-radius: 4px; background: #ffc107; font-size: 0.85em; font-weight: 600; }
    .macro-jurisdiction { padding: 1px 6px; border-radius: 3px; background: #f0f0f0; font-size: 0.85em; }
    footer { color: var(--muted); font-size: 0.8rem; text-align: center; }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #13161c; --card-bg: #1b1f27; --border: #2a2f3a; --text: #e6e9ef;
        --muted: #9aa3b2; --flag-bg: #2a2410; --flag-text: #fbbf24;
      }
    }
    @media (max-width: 480px) { main { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <header class="page">
    <h1>Screening {{ run_date }}</h1>
    <p>Universo: {{ universe_size }} &middot; Pasan Paso 1: {{ n_paso_1 }} &middot; Pasan Paso 2: {{ n_paso_2 }}</p>
  </header>
  {% if macro_events %}
  <section class="macro-banner">
    <h2>Eventos macro próximos (ventana 45 días)</h2>
    <ul>
    {% for ev in macro_events %}
      <li>
        <span class="macro-date">{{ ev.date }}</span>
        <span class="macro-days">en {{ ev.days_until }} días</span>
        <span class="macro-kind macro-kind-{{ ev.kind }}">{{ ev.kind_display }}</span>
        <span class="macro-jurisdiction">{{ ev.jurisdiction }}</span>
        <span class="macro-desc">{{ ev.description }}</span>
      </li>
    {% endfor %}
    </ul>
  </section>
  {% endif %}
  <main>
    {% for c in candidates %}
    <article class="card {{ c.tipo_T_lower }}">
      <header class="card-head">
        <strong class="ticker">{{ c.ticker }}</strong>
        {% if c.universes %}
        <span class="universe-badges">
          {% for u in c.universes %}
          <span class="universe-badge">{{ u }}</span>
          {% endfor %}
        </span>
        {% endif %}
        <span class="sector">{{ c.sector }}</span>
        <span class="exchange">{{ c.exchange }}</span>
        <span class="badge type-{{ c.tipo_T_lower }}">{{ c.tipo_T }}</span>
      </header>

      <div class="tier">
        <span class="tier-stars">{{ c.score_tier_stars }}</span>
        <span class="tier-label">{{ c.score_tier_label }}</span>
      </div>
      <div class="score-raw">Score crudo: {{ "%.1f"|format(c.score) }}</div>

      <section class="zone">
        <div class="metric">
          <span class="label">Spot</span>
          <span class="value">{{ c.spot_formatted }}</span>
        </div>
        <div class="metric">
          <span class="label">Zona</span>
          <span class="value">[{{ c.zona_min_formatted }} - {{ c.zona_max_formatted }}]</span>
        </div>
        <div class="metric">
          <span class="label">Distancia</span>
          <span class="value">{{ c.distancia_pct }}%</span>
        </div>
      </section>

      <section class="elements">
        <h4>Elementos ({{ c.n_elementos }})</h4>
        <ul>
          {% for element in c.elements[:8] %}
          <li>{{ element.label }} @ {{ element.price_formatted }}</li>
          {% endfor %}
          {% if c.n_elementos > 8 %}
          <li class="more">+{{ c.n_elementos - 8 }} más</li>
          {% endif %}
        </ul>
      </section>

      <section class="indicators">
        <div>RSI_d: {{ c.rsi_d }} &middot; RSI_w: {{ c.rsi_w }} &middot; MACD: {{ c.macd_estado }} &middot; Momentum: {{ c.momentum_score }}</div>
        <div>PT: {{ c.price_target_formatted }} ({{ c.pt_upside_pct }}%) &middot; Buy: {{ c.buy_ratio }}% &middot; Downgrades: {{ c.downgrades }}</div>
      </section>

      {% if c.flags_legibles %}
      <section class="flags warning">
        <h4>&#9888; Flags</h4>
        <ul>
          {% for flag in c.flags_legibles %}
          <li>{{ flag }}</li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if c.momentum_signals %}
      <section class="momentum">
        <h4>Señales de momentum</h4>
        <ul>
          {% for signal in c.momentum_signals %}
          <li>Divergencia ({{ signal }})</li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}
    </article>
    {% endfor %}
  </main>
  <footer>
    Generado: {{ generated_at }} &middot; puts-screener v{{ version }}
  </footer>
</body>
</html>
